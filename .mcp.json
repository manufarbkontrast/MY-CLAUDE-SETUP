{
  "mcpServers": {
    "lightpanda": {
      "command": "/opt/homebrew/bin/lightpanda",
      "args": ["mcp"]
    },
    "dbhub": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@bytebase/dbhub@latest",
        "--transport",
        "stdio",
        "--dsn",
        "${DATABASE_URL}"
      ]
    },
    "linkedin": {
      "command": "uvx",
      "args": ["linkedin-scraper-mcp"]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "presenton": {
      "type": "http",
      "url": "http://localhost:5000/mcp"
    }
  }
}
