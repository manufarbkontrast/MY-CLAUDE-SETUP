{
  "mcpServers": {
    "lightpanda": {
      "command": "/opt/homebrew/bin/lightpanda",
      "args": ["mcp"]
    },
    "dbhub": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@bytebase/dbhub@latest",
        "--transport",
        "stdio",
        "--dsn",
        "${DATABASE_URL}"
      ]
    },
    "linkedin": {
      "command": "uvx",
      "args": ["linkedin-scraper-mcp"]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "presenton": {
      "type": "http",
      "url": "http://localhost:5001/mcp"
    },
    "email": {
      "command": "uvx",
      "args": ["mcp-email-server@latest", "stdio"],
      "env": {
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "${EMAIL_ADDRESS}",
        "MCP_EMAIL_SERVER_PASSWORD": "${EMAIL_PASSWORD}",
        "MCP_EMAIL_SERVER_IMAP_HOST": "${EMAIL_IMAP_HOST}",
        "MCP_EMAIL_SERVER_SMTP_HOST": "${EMAIL_SMTP_HOST}"
      }
    }
  }
}
